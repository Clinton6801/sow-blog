# ============================================================
# THE SOW CHRONICLE — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase — get from: Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin password — choose something strong
ADMIN_PASSWORD=change-this-to-a-strong-password

# Your public site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Email notifications (optional — get free API key at resend.com)
RESEND_API_KEY=re_your_resend_api_key
NOTIFY_EMAIL=your-email@gmail.com

# Contact form destination (optional)
CONTACT_EMAIL=pressclub@sowschools.edu.ng
